# Server Configuration
PORT=5000
NODE_ENV=development

# Database Connection (MongoDB Atlas Connection String)
# Replace with your own MONGODB_URI. Never commit real credentials.
MONGODB_URI=mongodb+srv://<db_user>:<db_password>@<cluster-host>/<db_name>?retryWrites=true&w=majority

# CORS Allowed Origin
# Comma-separated list of permitted origins.
# Include both local development (localhost) and production frontend URL (Vercel domain).
CORS_ORIGIN=http://localhost:3000,https://your-frontend-domain.vercel.app
FRONTEND_URL=https://your-frontend-domain.vercel.app

# Authentication Configuration
# REQUIRED. The server refuses to start without this. Use a long random string.
JWT_SECRET=replace_with_a_long_random_secret

# Opt-in development-only mock auth. Leave unset/false in production.
# ALLOW_MOCK_AUTH=false

# Email Configuration (SMTP Settings for Nodemailer)
# For Gmail, SMTP_FROM MUST equal SMTP_USER (or a verified alias).
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_gmail_app_password
SMTP_FROM=your_email@gmail.com
# Where admin/clinic notifications are sent. Defaults to SMTP_USER if unset.
ADMIN_EMAIL=your_email@gmail.com

# Firebase Backend Configuration (Service Account)
# Used for FCM push notifications and Google Sign-In token verification.
FIREBASE_PROJECT_ID=your_firebase_project_id
FIREBASE_CLIENT_EMAIL=your_service_account_email@your_project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...your key...\n-----END PRIVATE KEY-----\n"

# Cloudinary Configuration (Optional - Preferred Storage)
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret
# Or configure using a single URL:
# CLOUDINARY_URL=cloudinary://API_KEY:API_SECRET@CLOUD_NAME

# Vercel Blob Storage Configuration (Optional - Alternative Storage)
BLOB_READ_WRITE_TOKEN=your_vercel_blob_token

